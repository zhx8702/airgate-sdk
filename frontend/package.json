{
  "name": "@airgate/theme",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./css": {
      "import": "./dist/css.js",
      "default": "./dist/css.js",
      "types": "./dist/css.d.ts"
    },
    "./tailwind": {
      "import": "./dist/tailwind.js",
      "default": "./dist/tailwind.js",
      "types": "./dist/tailwind.d.ts"
    },
    "./plugin": {
      "import": "./dist/plugin.js",
      "default": "./dist/plugin.js",
      "types": "./dist/plugin.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
